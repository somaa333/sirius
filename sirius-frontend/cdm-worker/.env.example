# Supabase project (same project as the SIRIUS frontend)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Service role key — NEVER expose in browser; worker only.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# Optional: identify this worker instance in DB heartbeats
WORKER_ID=worker-local-1

# Poll interval when no job (ms)
IDLE_POLL_MS=3000
