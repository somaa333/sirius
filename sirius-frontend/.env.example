# Copy to `.env` in this directory (Vite loads env from the project root).
# See README.md for setup.

# Supabase (required for auth and data)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# In Supabase Dashboard → Authentication → URL Configuration, set:
#   Site URL: https://<your-vercel-domain>
#   Redirect URLs: https://<your-vercel-domain>/reset-password
# (Password reset emails redirect there; Vercel needs vercel.json SPA rewrites.)

# FastAPI analysis service (required for Analysis page runs)
VITE_AI_API_BASE_URL=

# Optional: NASA APOD / space cards on the home experience
# VITE_NASA_API_KEY=
